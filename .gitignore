# --- Hugo specific ---
# The folder where the static site is generated
public/
# Hugo internal cache (processed images, minified assets, etc.)
resources/_gen/
# Build lock file to prevent concurrent builds
.hugo_build.lock

# --- Dynamic Data ---
# Ignore the HAL JSON file because it is generated by our script/Makefile.
# This prevents merge conflicts and keeps the Git history clean.
data/hal_publications.json

# --- Operating Systems ---
# Linux (Debian)
*~
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# --- Editors and IDEs ---
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Vim
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]uv[a-z]

# --- Miscellaneous ---
# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency folders (if using PostCSS, Tailwind, or specialized Hugo modules)
node_modules/
